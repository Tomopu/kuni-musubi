# =============================================================
# Backend（FastAPI）
# =============================================================
DATABASE_URL=postgresql://kuni_musubi:kuni_musubi@localhost:5432/kuni_musubi
CORS_ORIGINS=["http://localhost:3000"]
AUTO_SEED_DEMO_DATA=true
# 本番環境では必ず変更すること
ADMIN_SECRET_KEY=kuni-musubi-admin-dev-secret-change-in-production

# 本番フロントエンドURL（Vercel 等）。設定時は CORS 許可リストに自動追加される。
# 例: FRONTEND_URL=https://kuni-musubi.vercel.app
FRONTEND_URL=

# =============================================================
# Frontend（Next.js）— frontend/.env.local にコピーして使う
# =============================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# =============================================================
# Batch（記事収集・LLM 処理）
# =============================================================
# Gemini API キー（LLM 処理に必要。fetch-only モードは不要）
GEMINI_API_KEY=
LLM_MODEL=gemini-3-flash-preview

# スクレイパー設定（政治系サイトへの負荷を最小限にするデフォルト値）
SCRAPER_TIMEOUT=15
RSS_MAX_ITEMS=50
SCRAPER_REQUEST_DELAY_SECONDS=3.0
SCRAPER_DOMAIN_INTERVAL_SECONDS=10.0
SCRAPER_MAX_ITEMS_PER_RUN=30
SCRAPER_MAX_RETRIES=1
SCRAPER_BACKOFF_FACTOR=2.0

# =============================================================
# 実行時の PYTHONPATH 設定（コードではなく起動コマンドで指定）
# =============================================================
# バッチ単体実行（batch/ から）:
#   PYTHONPATH=..:../backend uv run python -m batch.main
#
# backend から batch 機能を使う場合（admin 画面のジョブ実行）:
#   PYTHONPATH=/workspaces/kuni-musubi uvicorn app.main:app  （開発）
#   PYTHONPATH=/app uvicorn app.main:app                      （本番）
