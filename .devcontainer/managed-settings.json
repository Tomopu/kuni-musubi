{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.production)",
      "Read(./.env.test)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.development)",
      "Read(./**/.env.production)",
      "Read(./**/.env.test)",
      "Read(./.claude/settings.local.json)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.development)",
      "Edit(./.env.production)",
      "Edit(./.env.test)",
      "Edit(./**/.env)",
      "Edit(./**/.env.local)",
      "Edit(./**/.env.development)",
      "Edit(./**/.env.production)",
      "Edit(./**/.env.test)",
      "Edit(./secrets/**)",
      "Edit(./**/secrets/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.config/gh/**)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.npmrc)",
      "Edit(~/.pypirc)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(printenv *)",
      "Bash(env)",
      "Bash(set)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(nc *)",
      "Bash(netcat *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git tag *)",
      "Bash(git clean *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(uv pip install *)",
      "Bash(poetry add *)",
      "Bash(poetry install *)"
    ],
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git restore --staged *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(sed -n *)",
      "Bash(nl *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(jq *)",
      "Bash(pwd)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(python3 --version)",
      "Bash(uv --version)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(npm test)",
      "Bash(npm run test)",
      "Bash(npm run test *)",
      "Bash(uv sync)",
      "Bash(uv sync *)",
      "Bash(uv lock)",
      "Bash(uv lock *)",
      "Bash(uv run pytest)",
      "Bash(uv run pytest *)",
      "Bash(pytest)",
      "Bash(pytest *)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(docker-compose ps*)",
      "Bash(docker-compose logs*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:files.pythonhosted.org)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "enableWeakerNestedSandbox": true,
    "filesystem": {
      "allowRead": [
        "."
      ],
      "denyRead": [
        "./.env",
        "./.env.local",
        "./.env.development",
        "./.env.production",
        "./.env.test",
        "./**/.env",
        "./**/.env.local",
        "./**/.env.development",
        "./**/.env.production",
        "./**/.env.test",
        "./secrets/**",
        "./**/secrets/**",
        "~/.ssh/**",
        "~/.aws/**",
        "~/.config/gh/**",
        "~/.docker/config.json",
        "~/.npmrc",
        "~/.pypirc"
      ],
      "denyWrite": [
        "/",
        "/etc/**",
        "/usr/**",
        "/bin/**",
        "/sbin/**",
        "/var/run/docker.sock",
        "~/.ssh/**",
        "~/.aws/**",
        "~/.config/gh/**",
        "~/.docker/config.json",
        "~/.npmrc",
        "~/.pypirc"
      ],
      "allowManagedReadPathsOnly": true
    },
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "claude.ai",
        "console.anthropic.com",
        "code.claude.com",
        "docs.claude.com",
        "docs.anthropic.com",
        "github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "registry.npmjs.org",
        "nodejs.org",
        "pypi.org",
        "files.pythonhosted.org"
      ],
      "deniedDomains": [
        "webhook.site",
        "*.requestcatcher.com",
        "*.ngrok-free.app",
        "*.ngrok.io"
      ],
      "allowManagedDomainsOnly": true,
      "allowAllUnixSockets": false,
      "allowLocalBinding": true
    }
  },
  "allowedHttpHookUrls": [],
  "httpHookAllowedEnvVars": [],
  "strictKnownMarketplaces": [],
  "disabledMcpjsonServers": [
    "filesystem"
  ]
}
